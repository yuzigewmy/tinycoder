+#!/usr/bin/env python3
+from pathlib import Path
+import sys
+
+repo_root = Path(__file__).resolve().parents[1]
+if str(repo_root) not in sys.path:
+    sys.path.insert(0, str(repo_root))
+
+from tinycoder.index import main_sync
+
+if __name__ == "__main__":
+    main_sync()
